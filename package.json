{
  "name": "kilovault",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:client": "crunchy build:client",
    "crunch": "crunchy build",
    "bundle": "tsx scripts/bundle.mts",
    "test": "crunchy build && vitest run",
    "test:nobuild": "vitest run",
    "dev": "nodemon --watch src --ext ts --exec \"pnpm run crunch && tsx --env-file=.env src/index.ts\"",
