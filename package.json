  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@bunny.net/edgescript-sdk": "^0.12.1",
    "@libsql/client": "^0.17.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "crunch.ts": "github:thomkin/crunch.ts#f8878d92618ed42473737ee24bc8b9b3e659c43d",
    "kysely": "^0.28.12",
    "typia": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "4.1.0",
    "cross-env": "^10.1.0",
    "deno": "^2.7.5",
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.14",
    "ts-patch": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
